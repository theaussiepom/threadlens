# ThreadLens environment example
# Copy to .env and adjust for local or Docker use.

THREADLENS_CONFIG_PATH=./examples/config/config.yaml
THREADLENS_MODE=server
TZ=Australia/Brisbane

# Optional overrides (see docs/configuration.md)
# THREADLENS_SITE_NAME=Home
# THREADLENS_SERVER_PORT=8128
# THREADLENS_AGENT_PORT=8129
